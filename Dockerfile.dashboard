# ============================================================
# Streamlit Dashboard - Dockerfile
# ============================================================
FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    fonts-noto-cjk \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY pyproject.toml ./
RUN pip install --no-cache-dir uv && \
    uv pip install --system --no-cache \
    streamlit==1.40.0 \
    fastapi==0.115.0 \
    httpx==0.27.0 \
    pyyaml==6.0.2 \
    openai==1.50.0 \
    pydantic==2.9.0 \
    && python -c "import streamlit; print('Streamlit OK')"

# 复制应用代码
COPY . .

# 暴露端口（Streamlit 默认 8501，但 Render 用 $PORT）
ENV STREAMLIT_SERVER_PORT=${PORT:-8501}
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_SERVER_RUN_ON_SAVE=true

EXPOSE ${STREAMLIT_SERVER_PORT}

# 启动命令：直接运行 Streamlit app.py（不使用 wrapper 脚本）
CMD ["streamlit", "run", "src/observability/dashboard/app.py", \
     "--server.port=${PORT:-8501}", \
     "--server.address=0.0.0.0", \
     "--browser.gatherUsageStats=false"]
