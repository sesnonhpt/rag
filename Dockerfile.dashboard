# ============================================================
# Streamlit Dashboard - Dockerfile
# ============================================================
FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖（libgl1 替代 libgl1-mesa-glx，Debian Trixie 已改名）
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    fonts-noto-cjk \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY pyproject.toml ./
RUN pip install --no-cache-dir uv && \
    uv pip install --system --no-cache \
    streamlit==1.40.0 \
    fastapi==0.115.0 \
    httpx==0.27.0 \
    pyyaml==6.0.2 \
    openai==1.50.0 \
    pydantic==2.9.0 \
    python-dotenv==1.0.1 \
    && python -c "import streamlit; print('Streamlit OK')"

# 复制应用代码
COPY . .

# 显式设置端口（Render 会注入 PORT 环境变量）
ENV PORT=10000
ENV PYTHONPATH=/app
ENV STREAMLIT_SERVER_PORT=10000
ENV STREAMLIT_SERVER_HEADLESS=true

EXPOSE 10000

# 启动命令
CMD ["streamlit", "run", "src/observability/dashboard/app.py", \
     "--server.port=10000", \
     "--server.address=0.0.0.0", \
     "--browser.gatherUsageStats=false"]
