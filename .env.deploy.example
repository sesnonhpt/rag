# ============================================================
# Modular RAG - 完整环境变量清单（Render 部署用）
# ============================================================
# 复制此文件为 .env，填入真实值后上传到 Render Dashboard
# 或直接在 Render Dashboard 界面逐项填写
# ============================================================

# ── LLM 配置（必填）────────────────────────────────────────
LLM_API_KEY=your_aihubmix_api_key_here
LLM_PROVIDER=openai
LLM_BASE_URL=https://aihubmix.com/v1
LLM_MODEL=coding-glm-5-free
# 可选模型: gemini-2.0-flash, gpt-4o

# ── Embedding 配置（必填）────────────────────────────────
EMBEDDING_API_KEY=your_aihubmix_api_key_here
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://aihubmix.com/v1
EMBEDDING_MODEL=qwen3-embedding-4b
EMBEDDING_DIMENSIONS=2560

# ── Vision LLM（可选 – PDF/图片理解）──────────────────────
VISION_LLM_API_KEY=your_aihubmix_api_key_here
VISION_LLM_PROVIDER=openai
VISION_LLM_BASE_URL=https://aihubmix.com/v1
VISION_LLM_MODEL=gpt-4o

# ── 向量数据库（必填 – Qdrant Cloud）──────────────────────
# 1. 注册 https://cloud.qdrant.io（GitHub 登录，免费方案）
# 2. 创建 Cluster（选择新加坡节点，免费）
# 3. 填入以下 3 个值：

VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=default
QDRANT_VECTOR_DIM=2560

# ── Observability ─────────────────────────────────────────
# 设为 false 避免写入本地 trace 文件（Render 免费版 HDD 会丢）
OBSERVABILITY_TRACE_ENABLED=false

# ── Lesson 生成优化 ───────────────────────────────────────
# 关闭第二轮 review / polish，优先保证生成稳定性
LESSON_REVIEW_ENABLED=false
