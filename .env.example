LLM_PROVIDER=openai
LLM_MODEL=coding-glm-5-free
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://aihubmix.com/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=qwen3-embedding-4b
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://aihubmix.com/v1
EMBEDDING_DIMENSIONS=2560

VISION_LLM_ENABLED=true
VISION_LLM_PROVIDER=openai
VISION_LLM_MODEL=gpt-4o
VISION_LLM_API_KEY=your-vision-api-key
VISION_LLM_BASE_URL=https://aihubmix.com/v1
VISION_LLM_MAX_IMAGE_SIZE=2048

VECTOR_STORE_PROVIDER=chroma
VECTOR_STORE_PERSIST_DIRECTORY=./data/db/chroma
VECTOR_STORE_COLLECTION_NAME=default

RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_FUSION_TOP_K=10
RETRIEVAL_RRF_K=60

RERANK_ENABLED=false
RERANK_PROVIDER=none
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=10

OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_TRACE_ENABLED=true
OBSERVABILITY_TRACE_FILE=./logs/traces.jsonl
OBSERVABILITY_STRUCTURED_LOGGING=true

LESSON_REVIEW_ENABLED=false
